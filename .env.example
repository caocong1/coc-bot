# ═══════════════════════════════════════════
# CoC Bot 环境变量配置
# 复制此文件为 .env 并填写实际值
# ═══════════════════════════════════════════

# ── 阿里云百炼 ──
DASHSCOPE_API_KEY=your_api_key_here
# 流式聊天超时（毫秒），默认 120000 = 120 秒
# DASHSCOPE_STREAM_TIMEOUT_MS=120000

# ── NapCatQQ 连接配置 ──
# 正向 WebSocket 地址（用于接收消息事件）
# 对应 NapCat 中 name="cocBot" 的 WebSocket 服务端
NAPCAT_WS_URL=ws://127.0.0.1:3003

# HTTP API 地址（用于发送消息、调用 API）
# 对应 NapCat 中 name="cocBot" 的 HTTP 服务端
NAPCAT_HTTP_URL=http://127.0.0.1:3002

# NapCat Token（如果 NapCat 设置了 token 鉴权，此处填写相同的值）
# 当前 cocBot 的 token 为空，无需填写
NAPCAT_TOKEN=

# ── 本机 Web 控制台 ──
SERVER_PORT=28765
# 房间审卡超时（毫秒），默认 1200000 = 20 分钟
# ROOM_REVIEW_TIMEOUT_MS=1200000

# 管理端登录密钥（访问 /admin 时需要填写）
ADMIN_SECRET=your_admin_secret_here

# 玩家端登录链接基础 URL（.web login 命令生成链接时使用）
# 生产环境设为 nginx 代理后的外网地址
WEB_BASE_URL=http://localhost:28765

# ── 今日人品兜底文案（可选覆盖） ──
# 默认读取项目内 src/commands/fun/jrrp.fallback.json
# 如需沿用你自己的旧文件（.jrrp.gugu.txt），可取消注释并填写路径
# JRRP_GUGU_FILE=C:\OneDrive\.jrrp.gugu.txt

# ── 数据库 ──
DATABASE_PATH=./data/storage/coc-bot.db

# ── 日志 ──
LOG_LEVEL=info
